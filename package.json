{
  "name": "ai-drama-generator",
  "version": "0.1.0",
  "description": "🎬 AI 短剧生成器 - 使用 AI 技术自动生成短剧剧本、分镜、配音一站式解决方案",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:app && electron-builder",
    "build:app": "vite build",
    "build:win": "npm run build:app && electron-builder --win",
    "build:mac": "npm run build:app && electron-builder --mac",
    "build:linux": "npm run build:app && electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .js,.ts,.vue",
    "test": "vitest",
    "ai:test": "python scripts/test_ai_services.py"
  },
  "keywords": [
    "ai",
    "drama",
    "generator",
    "video",
    "electron",
    "desktop",
    "text-to-video"
  ],
  "author": "xiaohei7529 <xiaohei7529@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vitest": "^1.1.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "element-plus": "^2.5.0",
    "lowdb": "^7.0.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "marked": "^11.0.0"
  },
  "optionalDependencies": {
    "ffmpeg-static": "^5.2.0",
    "python-bridge": "^1.2.2"
  },
  "build": {
    "appId": "com.ai.drama.generator",
    "productName": "AI 短剧生成器",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "scripts/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI 短剧生成器"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.png",
      "category": "Video"
    }
  }
}
